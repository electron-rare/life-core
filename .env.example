# Environment variables for life-core
ENV=dev

# --- eu-kiki gateway (electron-server:9300) ---
# Public gateway exposing all ailiance-* aliases. 11 aliases as of 2026-05-11.
# - ailiance-qwen      : Qwen3-Next 80B Q4_K_M (KXKM-AI llama.cpp, 262k ctx)
# - ailiance-granite   : Granite-4.1 30B Q4_K_M (KXKM-AI llama.cpp)
# - ailiance-gemma     : Gemma 3 4B IT GGUF (Tower P2000 llama.cpp)
# - ailiance-eurollm   : EuroLLM 22B (Studio MLX, FR/multilingue fine-tune)
# - ailiance-mistral-medium : Mistral-Medium 3.5 128B Q8 MLX (Studio :9301, launchd cc.ailiance.mistral.plist)
# - ailiance-mistral / ministral / ministral-reasoning / gemma2 / gemma4 : MLX bundle on macM1 :8502
KIKI_FULL_BASE_URL=http://electron-server:9300/v1
KIKI_FULL_MODELS=ailiance-qwen,ailiance-granite,ailiance-gemma,ailiance-eurollm,ailiance-mistral-medium,ailiance-mistral,ailiance-ministral,ailiance-ministral-reasoning,ailiance-gemma2,ailiance-gemma4
# KIKI_FULL_API_KEY=vllm-er-2026
